<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Phase 2.2a: System Parameters for Receiving Configuration -->
        
        <record id="param_default_container_type" model="ir.config_parameter">
            <field name="key">itad_core.default_container_type</field>
            <field name="value">PALLET</field>
        </record>
        
        <record id="param_default_scale_id" model="ir.config_parameter">
            <field name="key">itad_core.default_scale_id</field>
            <field name="value">DOCK-SCALE-01</field>
        </record>
        
        <record id="param_receipt_timeout_seconds" model="ir.config_parameter">
            <field name="key">itad_core.receipt_timeout_seconds</field>
            <field name="value">30</field>
        </record>
        
        <record id="param_max_receipt_weight_lbs" model="ir.config_parameter">
            <field name="key">itad_core.max_receipt_weight_lbs</field>
            <field name="value">100000</field>
        </record>
        
        <record id="param_bol_pattern" model="ir.config_parameter">
            <field name="key">itad_core.bol_pattern</field>
            <field name="value">^BOL-\d{4}-\d{6}$</field>
        </record>
        
        <record id="param_max_receipt_attempts_per_hour" model="ir.config_parameter">
            <field name="key">itad_core.max_receipt_attempts_per_hour</field>
            <field name="value">10</field>
        </record>
        
        <record id="param_audit_retention_days" model="ir.config_parameter">
            <field name="key">itad_core.audit_retention_days</field>
            <field name="value">180</field>
        </record>
        
        <!-- Phase 2.3: Taxonomy Sync Configuration -->
        
        <record id="param_taxonomy_sync_include_inactive" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.sync.include_inactive</field>
            <field name="value">true</field>
        </record>
        
        <record id="param_taxonomy_sync_incremental_enabled" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.sync.incremental_enabled</field>
            <field name="value">true</field>
        </record>
        
        <record id="param_taxonomy_sync_max_stale_hours" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.sync.max_stale_hours</field>
            <field name="value">24</field>
        </record>
        
        <record id="param_taxonomy_sync_timeout_seconds" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.sync.timeout_seconds</field>
            <field name="value">15</field>
        </record>
        
        <record id="param_taxonomy_sync_block_if_stale" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.sync.block_if_stale</field>
            <field name="value">true</field>
        </record>
        
        <record id="param_taxonomy_sync_overlap_seconds" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.sync.overlap_seconds</field>
            <field name="value">2</field>
        </record>
        
        <record id="param_taxonomy_sync_break_glass_enabled" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.sync.break_glass_enabled</field>
            <field name="value">false</field>
        </record>
        
        <!-- Phase 2.3 Extra Hardening: Audit Retention Config -->
        
        <record id="param_taxonomy_audit_retention_days" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.audit_retention_days</field>
            <field name="value">365</field>
        </record>
        
        <record id="param_taxonomy_audit_retention_mode" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.audit_retention_mode</field>
            <field name="value">archive</field>
        </record>
        
        <record id="param_taxonomy_audit_retention_grace_days" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.audit_retention_grace_days</field>
            <field name="value">30</field>
        </record>
        
        <!-- Phase 2.4 Enhancement: Admin-only delete mode enablement -->
        <record id="param_taxonomy_audit_retention_delete_enabled" model="ir.config_parameter">
            <field name="key">itad_core.taxonomy.audit_retention_delete_enabled</field>
            <field name="value">false</field>
        </record>
        
        <!-- Phase 2.5: Variance Detection Thresholds -->
        <record id="param_variance_percent_threshold" model="ir.config_parameter">
            <field name="key">itad_core.variance.percent_threshold</field>
            <field name="value">25</field>
        </record>
        
        <record id="param_variance_absolute_lbs_threshold" model="ir.config_parameter">
            <field name="key">itad_core.variance.absolute_lbs_threshold</field>
            <field name="value">500</field>
        </record>
        
        <!-- Phase 2.5: Outbox Alert Thresholds -->
        <record id="param_outbox_failures_threshold" model="ir.config_parameter">
            <field name="key">itad_core.ops.outbox_failures_threshold</field>
            <field name="value">5</field>
        </record>
        
        <record id="param_outbox_window_minutes" model="ir.config_parameter">
            <field name="key">itad_core.ops.outbox_window_minutes</field>
            <field name="value">60</field>
        </record>
    </data>
</odoo>
