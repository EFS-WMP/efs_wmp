<odoo>
    <data>
        <record id="ir_cron_itad_outbox_process" model="ir.cron">
            <field name="name">ITAD Core Outbox Processor</field>
            <field name="model_id" ref="model_itad_core_outbox"/>
            <field name="state">code</field>
            <field name="code">model._cron_process_itad_outbox()</field>
