<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Phase 2.5: Operations Health Cron Jobs -->
    
    <!-- Compute Alerts (every 15 minutes) -->
    <record id="cron_itad_ops_alerts_compute" model="ir.cron">
        <field name="name">ITAD: Compute Operations Alerts</field>
        <field name="model_id" ref="model_itad_ops_alert"/>
        <field name="state">code</field>
        <field name="code">model._cron_compute_alerts()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>

        <field name="active">True</field>
    </record>
    
    <!-- Evaluate Variance (every 30 minutes) -->
    <record id="cron_itad_variance_evaluate" model="ir.cron">
        <field name="name">ITAD: Evaluate Order Variance</field>
        <field name="model_id" ref="model_fsm_order"/>
        <field name="state">code</field>
        <field name="code">model._cron_evaluate_variance()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>

        <field name="active">True</field>
    </record>
    
</odoo>
