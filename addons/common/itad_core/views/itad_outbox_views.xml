<odoo>
    <data>
        <record id="view_itad_outbox_tree" model="ir.ui.view">
            <field name="name">itad.core.outbox.tree</field>
            <field name="model">itad.core.outbox</field>
            <field name="arch" type="xml">
                <list>
                    <field name="order_id"/>
                    <field name="state"/>
                    <field name="idempotency_key"/>
                    <field name="correlation_id"/>
                    <field name="attempt_count"/>
                    <field name="next_retry_at"/>
                    <field name="last_http_status"/>
                    <field name="itad_pickup_manifest_id"/>
                    <field name="itad_manifest_no"/>
                    <field name="itad_bol_id"/>
                    <field name="itad_receiving_weight_record_id"/>
                    <field name="last_error"/>
                    <field name="dead_letter_reason"/>
                </list>
            </field>
        </record>

        <record id="view_itad_outbox_form" model="ir.ui.view">
            <field name="name">itad.core.outbox.form</field>
            <field name="model">itad.core.outbox</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button
                            name="action_requeue"
                            type="object"
                            string="Requeue"
                            class="oe_highlight"
                            groups="itad_core.group_receiving_manager"
                            modifiers="{'invisible': [['state', 'not in', ['failed', 'dead_letter']]]}"
                        />
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="order_id" readonly="1"/>
                                <field name="state" readonly="1"/>
                                <field name="idempotency_key" readonly="1"/>
                                <field name="correlation_id" readonly="1"/>
                                <field name="attempt_count" readonly="1"/>
                                <field name="next_retry_at" readonly="1"/>
                                <field name="last_http_status" readonly="1"/>
                                <field name="dead_letter_reason" readonly="1"/>
                            </group>
                            <group>
                                <field name="itad_pickup_manifest_id" readonly="1"/>
                                <field name="itad_manifest_no" readonly="1"/>
                                <field name="itad_bol_id" readonly="1"/>
                                <field name="itad_geocode_gate" readonly="1"/>
                                <field name="itad_receiving_weight_record_id" readonly="1"/>
                                <field name="itad_receiving_id" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="payload_sha256" readonly="1"/>
                            <field name="last_error" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_itad_outbox_search" model="ir.ui.view">
            <field name="name">itad.core.outbox.search</field>
            <field name="model">itad.core.outbox</field>
            <field name="arch" type="xml">
                <search>
                    <field name="order_id"/>
                    <field name="state"/>
                    <field name="idempotency_key"/>
                    <filter string="Ready to Send" name="ready_to_send" domain="[('state', '=', 'pending')]"/>
                    <filter string="Failed (Retrying)" name="failed_retrying" domain="[('state', '=', 'failed')]"/>
                    <filter string="Dead Letter" name="dead_letter" domain="[('state', '=', 'dead_letter')]"/>
                </search>
            </field>
        </record>

        <record id="action_itad_outbox" model="ir.actions.act_window">
            <field name="name">ITAD Outbox</field>
            <field name="res_model">itad.core.outbox</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_itad_outbox_search"/>
            <field name="domain">[]</field>
        </record>

        <record id="action_itad_outbox_failed" model="ir.actions.act_window">
            <field name="name">ITAD Outbox (Failed)</field>
            <field name="res_model">itad.core.outbox</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_itad_outbox_search"/>
            <field name="domain">[('state','=','failed')]</field>
        </record>

        <record id="action_itad_outbox_dead_letter" model="ir.actions.act_window">
            <field name="name">ITAD Outbox (Dead Letter)</field>
            <field name="res_model">itad.core.outbox</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_itad_outbox_search"/>
            <field name="domain">[('state','=','dead_letter')]</field>
        </record>

        <menuitem
            id="menu_itad_outbox"
            name="Outbox"
            parent="menu_itad_root"
            action="action_itad_outbox"
            sequence="10"
        />
        <menuitem
            id="menu_itad_outbox_failed"
            name="Outbox (Failed)"
            parent="menu_itad_root"
            action="action_itad_outbox_failed"
            sequence="20"
        />
        <menuitem
            id="menu_itad_outbox_dead_letter"
            name="Outbox (Dead Letter)"
            parent="menu_itad_root"
            action="action_itad_outbox_dead_letter"
            sequence="30"
        />
    </data>
</odoo>
